{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "BucketAccess",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject"
			],
			"Resource": "arn:aws:s3:::vm-ceo-crawler/crawler/*"
		},
		{
			"Sid": "BucketList",
			"Effect": "Allow",
			"Action": [
				"s3:ListBucket"
			],
			"Resource": "arn:aws:s3:::vm-ceo-crawler"
		}
	]
}